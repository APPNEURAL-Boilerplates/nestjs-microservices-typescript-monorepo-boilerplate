{
  "name": "nestjs-microservices-typescript-monorepo-boilerplate",
  "version": "1.0.0",
  "description": "NestJS microservices monorepo boilerplate with API Gateway, NATS, shared libs, and Docker Compose.",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build gateway && nest build users && nest build orders",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start gateway",
    "start:gateway": "nest start gateway",
    "start:users": "nest start users",
    "start:orders": "nest start orders",
    "start:dev": "concurrently -k -n gateway,users,orders -c auto \"npm:dev:gateway\" \"npm:dev:users\" \"npm:dev:orders\"",
    "dev:gateway": "nest start gateway --watch",
    "dev:users": "nest start users --watch",
    "dev:orders": "nest start orders --watch",
    "start:prod:gateway": "node dist/apps/gateway/main.js",
    "start:prod:users": "node dist/apps/users/main.js",
    "start:prod:orders": "node dist/apps/orders/main.js",
    "lint": "eslint \"{apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "npm run lint && npm run typecheck && npm test",
    "docker:up": "docker compose up -d nats",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "nats": "^2.29.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@app/common$": "<rootDir>/libs/common/src",
      "^@app/common/(.*)$": "<rootDir>/libs/common/src/$1",
      "^@app/contracts$": "<rootDir>/libs/contracts/src",
      "^@app/contracts/(.*)$": "<rootDir>/libs/contracts/src/$1"
    },
    "collectCoverageFrom": ["apps/**/*.ts", "libs/**/*.ts"],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node"
  }
}
